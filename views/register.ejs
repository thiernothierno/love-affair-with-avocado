<%- include ("partials/log-registerHeader.ejs") %>
<h1 class="sign-in-form">Register</h1>
<form action="/user-register" method="post">
    <label for="email">Email</label>
    <input type="email" name="email" placeholder="Enter an email address" required>
    <label for="password">Password</label>
    <input type="text" name="password" placeholder="Enter password" required>
    <label for="password">Repeat Password</label>
    <input type="text" name="repeat_password" placeholder="Reenter password" required> 
    <input type="submit" value="Submit">

</form>


